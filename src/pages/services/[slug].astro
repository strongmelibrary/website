---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import { ConfiguredHeader } from '../../components/Header/Header';
import { ConfiguredFooter } from '../../components/Footer/Footer';
import Tag from '../../components/Tag/Tag';
import PostDates from '../../components/PostDates/PostDates';
import { BASE_URL, CONTACT_INFO } from '../../config';

export async function getStaticPaths() {
  const serviceEntries = await getCollection('services');
  return serviceEntries.map((entry) => ({
    params: { slug: entry.id.replace(/\/index$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, publishedAt, heroImage, tags } = entry.data;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={title || ''} description={description || ''} />
  </head>
  <body class="bg-[var(--color-paper)] text-[var(--color-charcoal)]">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-[var(--color-forest)] focus:text-white focus:rounded focus:outline-none"
    >
      Skip to main content
    </a>
    <ConfiguredHeader client:load />

    <main id="main-content">
      <article>
        {
          heroImage && (
            <div
              class="w-full h-[50vh] bg-no-repeat bg-center bg-cover relative"
              role="img"
              aria-label={`Hero image for ${title || 'Service'}`}
              style={{ backgroundImage: `url("${BASE_URL + heroImage}")` }}
            >
            </div>
          )
        }
        <div
          class="mt-12 prose prose-sm sm:prose-base md:prose-lg lg:prose-xl xl:prose-2xl mx-auto p-4 prose-headings:font-heading prose-headings:text-[var(--color-charcoal)] prose-a:text-[var(--color-terracotta)] prose-a:no-underline hover:prose-a:underline"
        >
          <nav aria-label="Breadcrumb" class="not-prose mb-6">
            <a
              href={`${BASE_URL}services`}
              class="type-body-sm text-[var(--color-charcoal)]/60 hover:text-[var(--color-terracotta)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-forest)]"
            >
              ← Services
            </a>
          </nav>
          <h1 class="type-heading-lg text-[var(--color-charcoal)]">{title}</h1>
          <div class="flex flex-col space-y-4 not-prose">
            <div class="flex flex-row flex-wrap gap-2">
              {
                tags?.map((tag) => (
                  <Tag key={tag} href={`${BASE_URL}tags/${tag}`}>
                    {tag}
                  </Tag>
                ))
              }
            </div>
            <div class="flex flex-row flex-wrap space-x-4">
              <PostDates
                publishedAt={publishedAt}
              />
            </div>
          </div>
          <div class="mt-8"></div>
          <Content />
        </div>
      </article>
    </main>
    <ConfiguredFooter contactInfo={CONTACT_INFO} />
  </body>
</html>
