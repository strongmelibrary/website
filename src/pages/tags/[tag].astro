---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import { ConfiguredHeader } from '../../components/Header/Header';
import { ConfiguredFooter } from '../../components/Footer/Footer';
import { ReadMoreBlock } from '../../components/ReadMoreBlock/ReadMoreBlock';
import { SITE_TITLE, SITE_DESCRIPTION, BASE_URL, CONTACT_INFO } from '../../config';
import dayjs from 'dayjs';

export async function getStaticPaths() {
  const newsEntries = await getCollection('news');
  const serviceEntries = await getCollection('services');
  const allEntries = [...newsEntries, ...serviceEntries];

  const allTags = [...new Set(allEntries.flatMap((entry) => entry.data.tags || []))];

  return allTags.map((tagName) => {
    const taggedEntries = allEntries.filter((entry) =>
      entry.data.tags?.includes(tagName)
    );
    return {
      params: { tag: tagName },
      props: { entries: taggedEntries, tag: tagName },
    };
  });
}

const { entries, tag } = Astro.props;
const sortedEntries = entries.sort(
  (a, b) =>
    new Date(b.data.publishedAt || '').valueOf() - new Date(a.data.publishedAt || '').valueOf(),
);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={`Posts tagged: ${tag} | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-[var(--color-paper)] text-[var(--color-charcoal)]">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-[var(--color-forest)] focus:text-white focus:rounded focus:outline-none"
    >
      Skip to main content
    </a>
    <ConfiguredHeader client:load />

    <main id="main-content" class="max-w-4xl mx-auto px-4 py-12">
      <nav aria-label="Breadcrumb" class="mb-6">
        <a
          href={`${BASE_URL}tags`}
          class="type-body-sm text-[var(--color-charcoal)]/60 hover:text-[var(--color-terracotta)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-forest)]"
        >
          ← Browse by Topic
        </a>
      </nav>
      <span class="tag mb-4 inline-block">{tag}</span>
      <h1 class="type-heading-lg text-[var(--color-charcoal)] mb-8">Posts tagged: {tag}</h1>
      {sortedEntries.length > 0 ? (
        sortedEntries.map((entry) => {
          const collectionType = entry.collection;
          const url = `${BASE_URL}${collectionType === 'news' ? 'news' : 'services'}/${entry.id.replace(/\/index$/, '')}`;
          return (
            <ReadMoreBlock
              title={entry.data.title}
              titleSize="xs"
              subtitle={entry.data.description}
              url={url}
              linkText={
                entry.data.publishedAt
                  ? `Posted on: ${dayjs(entry.data.publishedAt).format('MMMM D, YYYY')}`
                  : ''
              }
            />
          );
        })
      ) : (
        <p class="type-body text-[var(--color-charcoal)]/70">No posts found for this topic.</p>
      )}
    </main>
    <ConfiguredFooter contactInfo={CONTACT_INFO} />
  </body>
</html>
