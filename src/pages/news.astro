---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import { ConfiguredHeader } from '../components/Header/Header';
import { ConfiguredFooter } from '../components/Footer/Footer';
import { SITE_TITLE, SITE_DESCRIPTION, BASE_URL, CONTACT_INFO } from '../config';
import { ReadMoreBlock } from '../components/ReadMoreBlock/ReadMoreBlock';
import dayjs from 'dayjs';

const newsEntries = await getCollection('news');
const posts = newsEntries.sort(
  (a, b) =>
    new Date(b.data.publishedAt || '').valueOf() - new Date(a.data.publishedAt || '').valueOf(),
);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={`Library News | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-[var(--color-paper)] text-[var(--color-charcoal)]">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-[var(--color-forest)] focus:text-white focus:rounded focus:outline-none"
    >
      Skip to main content
    </a>
    <ConfiguredHeader client:load />

    <main id="main-content" class="max-w-4xl mx-auto px-4 py-12">
      <h1 class="type-heading-lg text-[var(--color-charcoal)] mb-8">Library News</h1>
      {posts.length > 0 ? (
        posts.map((post) => (
          <ReadMoreBlock
            title={post.data.title}
            titleSize="xs"
            subtitle={post.data.description}
            url={`${BASE_URL}news/${post.id.replace(/\/index$/, '')}`}
            linkText={
              post.data.publishedAt
                ? `Posted on: ${dayjs(post.data.publishedAt).format('MMMM D, YYYY')}`
                : ''
            }
          />
        ))
      ) : (
        <p class="type-body text-[var(--color-charcoal)]/70">No news available.</p>
      )}
    </main>
    <ConfiguredFooter contactInfo={CONTACT_INFO} />
  </body>
</html>
