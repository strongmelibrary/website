---
import { getEntry, render } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import { ConfiguredHeader } from '../components/Header/Header';
import { ConfiguredFooter } from '../components/Footer/Footer';
import { BASE_URL } from '../config';

const servicesPage = await getEntry('pages', 'services');
if (!servicesPage) {
  return Astro.redirect(BASE_URL);
}

const { Content } = await render(servicesPage);
const { title, description, updatedAt, heroImage } = servicesPage.data;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={title || 'Services'} description={description || ''} />
  </head>
  <body class="dark:bg-slate-900">
    <ConfiguredHeader />

    <main>
      <article>
        {
          heroImage && (
            <div
              class="w-full h-screen/2 bg-no-repeat bg-center bg-cover relative"
              style={{ backgroundImage: `url("${heroImage}")` }}
            >
            </div>
          )
        }
        <div
          class="mt-12 prose prose-sm sm:prose-base md:prose-lg lg:prose-xl xl:prose-2xl dark:prose-invert prose-slate mx-auto p-4"
        >
          <h1>{title}</h1>
          <div class="h-16"></div>
          <Content />
        </div>
      </article>
    </main>
    <ConfiguredFooter />

  </body>
</html>
