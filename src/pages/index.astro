---
import { getCollection } from 'astro:content';

const searchParam = Astro.url.searchParams.get('search');
const redirectUrl = searchParam ? `/catalog?q=${encodeURIComponent(searchParam)}&page=1` : null;

import BaseHead from '../components/BaseHead.astro';
import { ConfiguredHeader } from '../components/Header/Header';
import { ConfiguredFooter } from '../components/Footer/Footer';

import { SITE_TITLE, SITE_DESCRIPTION, BASE_URL, LIBRARY_HOURS, CONTACT_INFO, HOMEPAGE_SETTINGS } from '../config';
import { HeroIndex } from '../components/HeroIndex/HeroIndex';
import type { Post } from '../components/HeroIndex/HeroIndex';
import TodaysHours from '../components/TodaysHours/TodaysHours';

import clsx from 'clsx';
import { LibraryHoursBlock } from '../components/LibraryHoursBlock/LibraryHoursBlock';
import { ReadMoreBlock } from '../components/ReadMoreBlock/ReadMoreBlock';
import dayjs from 'dayjs';
import { GLOBAL_LINKS, SOCIAL_LINKS } from '../constants';

const newsEntries = await getCollection('news');
const news = newsEntries.sort(
  (a, b) =>
    new Date(b.data.publishedAt || '').valueOf() - new Date(a.data.publishedAt || '').valueOf(),
).slice(0, 3).map((entry) => ({
  title: entry.data.title,
  url: `${BASE_URL}news/${entry.id.replace(/\/index$/, '')}`,
  date: entry.data.publishedAt
    ? new Date(entry.data.publishedAt).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })
    : '',
  category: entry.data.tags?.[0],
  description: entry.data.description || '',
}));

// Quick links from CMS homepage settings, mapped to Post type
const today = new Date().toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const quickLinks: Post[] = (HOMEPAGE_SETTINGS.heroQuickLinks || []).map(link => ({
  title: link.title,
  url: link.url.startsWith('/') ? BASE_URL + link.url.replace(/^\//, '') : link.url,
  date: today,
  description: link.description || '',
}));
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <script define:vars={{ baseUrl: BASE_URL }}>
      document.addEventListener('DOMContentLoaded', function() {
        var searchInput = document.querySelector('.bg-info-dark input');
        var searchButton = document.querySelector('.bg-info-dark button');
        
        if (searchInput && searchButton) {
          searchButton.addEventListener('click', function() {
            var searchTerm = searchInput.value.trim();
            if (searchTerm) {
              window.location.href = baseUrl + 'catalog?q=' + encodeURIComponent(searchTerm) + '&page=1';
            }
          });
          
          searchInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
              e.preventDefault();
              var searchTerm = searchInput.value.trim();
              if (searchTerm) {
                window.location.href = baseUrl + 'catalog?q=' + encodeURIComponent(searchTerm) + '&page=1';
              }
            }
          });
        }
      });
    </script>
  </head>
  <body class="dark:bg-slate-900">
    
    <ConfiguredHeader />
    <HeroIndex
      posts={quickLinks}
      heroTagline={HOMEPAGE_SETTINGS.heroTagline}
      heroImagePath={HOMEPAGE_SETTINGS.heroImagePath}>
      <TodaysHours client:only libraryHours={LIBRARY_HOURS} />
    </HeroIndex>
    <main
      class={clsx(
        "grid",
        "mt-8",
        "md:grid-cols-3",
        "grid-cols-1",
        "gap-y-[32px]",
        "gap-x-[32px]",
        "lg:w-4xl",
        "lg:mx-auto",
        "lg:px-0",
        "px-[16px]",
        "w-full"
      )}
    >
      <div class={clsx(
        "md:col-span-2",
        "col-span-1",
        "flex",
        "flex-col",
        "relative",
        "h-auto",
      )}>
        <div class={clsx(
          "w-full",
          "md:order-first",
          "order-last"
        )}>
          <h2 class="text-2xl font-bold mb-4">Latest News</h2>
          {news.length > 0 ? (
            news.map((post) => (
              <ReadMoreBlock
                title={post.title}
                titleSize="xs"
                subtitle={post.description}
                category={post.category}
                url={post.url}
                linkText={
                  `Posted on: ${dayjs(post.date).format('MMMM D, YYYY')}`
                }
              />
            ))
          ) : (
            <p>No news available.</p>
          )}
        </div>
      </div>
      <div
      class={clsx(
        "col-span-1",
        "flex",
        "flex-col",
        "items-start",
        "justify-start",
        "gap-2"
      )}
    >
        <LibraryHoursBlock libraryHours={LIBRARY_HOURS} />
      </div>
    </main>
    <ConfiguredFooter contactInfo={CONTACT_INFO} />
  </body>
</html>
